<style>
    /* ====== V2 UI (Front Only) ====== */
    .ex-page .pv-shell {
        max-width: 1280px;
        margin: 0 auto;
        padding: 10px 14px 24px;
    }

    .ex-page .pv-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        margin: 8px 0 12px;
    }

    .ex-page .pv-title {
        font-size: 22px;
        font-weight: 900;
        color: #0b2b40;
        margin: 0;
    }

    .ex-page .pv-sub {
        font-size: 13px;
        font-weight: 700;
        color: rgba(15,23,42,.65);
        margin-top: 4px;
    }

    .ex-page .pv-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .ex-page .pv-btn {
        border-radius: 14px;
        font-weight: 900;
        padding: 10px 14px;
        display: inline-flex;
        gap: 10px;
        align-items: center;
        white-space: nowrap;
    }

    .ex-page .pv-card {
        background: #fff;
        border: 1px solid rgba(0,0,0,.08);
        border-radius: 18px;
        box-shadow: 0 12px 30px rgba(15,23,42,.06);
        padding: 0;
        overflow: hidden;
    }

    .pv-card-head {
        padding: 12px 14px;
        background: rgba(24,169,153,.10);
        border-bottom: 1px solid rgba(0,0,0,.08);
    }

    .pv-card-title {
        font-size: 16px;
        font-weight: 900;
        color: #0b2b40;
        margin: 0;
    }

    .pv-card-body {
        padding: 14px;
    }

    /* Controls */
    .ex-controls {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        align-items: end;
        justify-content: space-between;
        margin: 8px 0 12px;
    }

        .ex-controls label {
            font-size: 13px;
            font-weight: 900;
            color: rgba(15,23,42,.65);
            margin-bottom: 6px;
        }

    #daterange {
        width: 320px;
        min-height: 44px;
        border-radius: 14px;
        font-size: 16px;
        padding: 8px 12px;
    }

    #Search {
        min-height: 44px;
        border-radius: 14px;
        font-weight: 900;
        padding: 8px 18px;
        white-space: nowrap;
    }

    #PrintAll {
        border-radius: 14px;
        font-weight: 900;
        min-height: 46px;
        padding: 10px 18px;
        width: min(420px, 100%);
    }

    /* Table wrap */
    .ex-table-wrap {
        overflow: auto;
        border-radius: 14px;
        border: 1px solid rgba(0,0,0,.08);
        background: #fff;
    }

        .ex-table-wrap table {
            min-width: 1000px;
        }

    table.table7899, table.table78991 {
        width: 100%;
        border-collapse: collapse;
        background: #fff;
    }

        table.table7899 th, table.table78991 th {
            background: rgba(24,169,153,.12);
            color: #0b2b40;
            font-weight: 900;
            padding: 10px;
            border: 1px solid rgba(0,0,0,.08);
            text-align: center;
            white-space: nowrap;
        }

        table.table7899 td, table.table78991 td {
            padding: 10px;
            border: 1px solid rgba(0,0,0,.08);
            text-align: center;
            white-space: nowrap;
            font-weight: 700;
            font-size: 13px;
        }

    /* Loading overlay */
    #backring1 {
        background-color: rgba(0,0,0,.25);
        display: none;
        position: fixed;
        inset: 0;
        z-index: 9998;
    }

    .ring1 {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%,-50%);
        width: 150px;
        height: 150px;
        border: 3px solid #9ac3b8;
        border-radius: 50%;
        text-align: center;
        line-height: 150px;
        font-size: 20px;
        letter-spacing: 2px;
        color: #fff000;
        text-transform: uppercase;
        text-shadow: 0 0 10px #fff000;
        background-color: #11395c;
        box-shadow: 0 0 20px rgba(0,0,0,.35);
        display: none;
        z-index: 9999;
    }

        .ring1:before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: 3px solid transparent;
            border-top: 3px solid #fff000;
            border-right: 3px solid #fff000;
            box-shadow: 0 0 1em white, 0 0 0 1000vw rgba(224,222,222,.70);
            border-radius: 50%;
            animation: animateC1 2s linear infinite;
        }

    spana1 {
        display: block;
        position: absolute;
        top: calc(50% - 2px);
        left: 50%;
        width: 50%;
        height: 4px;
        background: transparent;
        transform-origin: left;
        animation: animate1 2s linear infinite;
    }

        spana1:before {
            content: '';
            position: absolute;
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background: #fff000;
            top: -6px;
            right: -8px;
            box-shadow: 0 0 20px #fff000;
        }

    @@keyframes animateC1 {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    @@keyframes animate1 {
        0% {
            transform: rotate(45deg);
        }

        100% {
            transform: rotate(405deg);
        }
    }
</style>

<div class="ex-page">
    <div class="pv-shell">

        <div class="pv-header">
            <div>
                <div class="pv-title">@T("Title", "Print ClaimForm")</div>
                <div class="pv-sub">@T("SubTitle", "Select a date range to list claim forms, then view or print")</div>
            </div>

            <div class="pv-actions">
                <a class="btn btn-outline-secondary pv-btn" href="@Url.Action("DoctorHome","ClaimForm")">
                    <i class="bi bi-arrow-left"></i>
                    <span>@T("BackHome", "Back to Main Home")</span>
                </a>

                @* روابط إضافية لو حابب ترجعها لاحقاً بنفس نظامك *@
            </div>
        </div>

        <div class="pv-card">
            <div class="pv-card-head">
                <div class="pv-card-title">@T("CardTitle", "ClaimForm Data")</div>
            </div>

            <div class="pv-card-body">

                <div class="ex-controls">
                    <div>
                        <label for="daterange">@T("SelectDateRange", "Select Date Range")</label><br />
                        <input type="text" name="daterange" id="daterange" class="daterange" />
                    </div>

                    <div>
                        <button type="button" id="Search" class="btn btn-primary">
                            <i class="bi bi-search"></i> @T("Search", "Search")
                        </button>
                    </div>
                </div>

                <div class="ex-table-wrap">
                    <table class="table7899" id="ClaimFormTable" cellpadding="0" cellspacing="0">
                        <thead>
                            <tr>
                                <th>@T("Col_Serial", "Serial")</th>
                                <th>@T("Col_ApprovalID", "Approval ID")</th>
                                <th>@T("Col_ClaimFormNum", "ClaimForm Number")</th>
                                <th>@T("Col_CardNumber", "Card Number")</th>
                                <th>@T("Col_MemberName", "Member Name")</th>
                                <th>@T("Col_ProcedureDate", "Procedure Date")</th>
                                <th>@T("Col_Show", "Show")</th>
                                <th>@T("Col_Print", "Print")</th>
                                @* Delete موجود بالـ JS لكن زرّه كان متشال عندك في الجدول *@
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>

                <div class="text-center mt-3" id="diagnosis">
                    <button type="button" id="PrintAll" class="btn btn-info btn-lg">
                        <i class="bi bi-printer"></i> @T("PrintAll", "Print All Claim Forms Pdf")
                    </button>
                </div>

            </div>
        </div>

        @* Modal *@
        <div class="modal" id="myModal" role="dialog">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content" style="border-radius:18px;overflow:hidden">
                    <div class="modal-header">
                        <h5 class="modal-title" style="font-weight:900">@T("ModalTitle", "Invoice Services")</h5>
                        <button type="button" class="btn-close btn-danger" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">
                        <div class="ex-table-wrap">
                            <table class="table78991" id="ClaimServicesTable" cellpadding="0" cellspacing="0">
                                <thead>
                                    <tr>
                                        <th>@T("Svc_Serial", "Serial")</th>
                                        <th>@T("Svc_Name", "Service Name")</th>
                                        <th>@T("Svc_Qnt", "Service Qnt")</th>
                                        <th>@T("Svc_Note", "Service Note")</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-danger btn-lg" data-bs-dismiss="modal" style="border-radius:14px;font-weight:900">
                            @T("ModalClose", "Close")
                        </button>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>

<div id="backring1">
    <div class="ring1" id="Loadingg">
        @T("Loading", "Loading")
        <spana1></spana1>
    </div>
</div>

<script>
    function exShowLoading() { $('#backring1').show(); $('#Loadingg').show(); }
    function exHideLoading() { $('#Loadingg').hide(); $('#backring1').hide(); }

    $(document).ready(function () {
        exHideLoading();


        // DataTables
        $('#ClaimFormTable').DataTable({ paging: true });
        $('#ClaimServicesTable').DataTable({ paging: false });
        // ✅ Flag: يمنع التشغيل التلقائي أكثر من مرة
        var autoSearchDone = false;

        $("body").on("click", "#Search", function () {

            exShowLoading();

            $.get("/ClaimForm/GetClaimFormsDateRange", { id: $('#daterange').val() }, function (data) {
                exHideLoading();

                var t = $('#ClaimFormTable').DataTable();
                t.rows().remove().draw();

                if (data == "Falsee") {
                    Swal.fire("@T("Warning","Warning !")", "@T("Msg_InvalidDateRange","Select A Valid Date Range Again")", "warning");
                }
                else {
                    if (data.length != 0) {
                        serialll11 = 0;

                        for (var i = 0; i < data.length; i++) {

                            serialll11++;
                            var btnshow = "<button type='button' class='btn btn-warning' data-bs-toggle='modal' data-bs-target='#myModal' style='text-align:center' onclick='show(this);'>@T("Col_Show","Show")</button>";
                            var btnPrint = "<button type='button' class='btn btn-success' style='text-align:center' onclick='Print(this);'>@T("Col_Print","Print")</button>";
                            // var btnDelete = "<button type='button' class='btn btn-danger' style='text-align:center' onclick='Delete(this);'>@T("Col_Delete","Delete")</button>";

                            t.row.add([
                                serialll11,
                                data[i].ApprovalID,
                                data[i].ClaimFormNum,
                                data[i].CardNumber,
                                data[i].MemberName,
                                moment(data[i].ProcedureDate).format("DD-MM-YYYY"),
                                btnshow,
                                btnPrint
                                // ,btnDelete
                            ]).draw();
                        }
                    }
                }
            })
        });
        // ✅ تشغيل تلقائي مرة واحدة فقط عند فتح الصفحة
        if (!autoSearchDone) {
            autoSearchDone = true;
            $("#Search").trigger("click");
        }
        $("body").on("click", "#PrintAll", function () {

            Swal.fire({
                title: "@T("Confirm","Confirm")",
                imageUrl: "/Images/Quationimg.jpg",
                imageWidth: 550,
                imageHeight: 225,
                text: "@T("Msg_ConfirmPrintAll","Are you Sure you want to Print All Claim Forms Pdf?")",
                showCancelButton: true,
                confirmButtonText: "@T("Confirm","Confirm")",
                cancelButtonColor: "#700c0c"
            }).then((result) => {

                if (result.isConfirmed) {
                    var table = $('#ClaimFormTable').DataTable();
                    table.rows().every(function () {
                        var Row = this.data();
                        var Approval_ID = Row[1];
                        window.open('@Url.Action("GenerateReport_PrintClaimForm", "ClaimForm")?typeOfReport=PDF' + '&ApprovalID=' + Approval_ID, '_blank');
                    });
                }
            });
        });
    });

    function show(button) {
        exShowLoading();

        var row = $(button).closest("TR");
        var ClaimID = row[0].cells.item(1).innerHTML;

        var t1 = $('#ClaimServicesTable').DataTable();
        t1.rows().remove().draw();

        $.get("/ClaimForm/Get_Doctor_ClaimFormServices", { ApprovalID: ClaimID }, function (data) {
            exHideLoading();

            if (data.length != 0) {
                seria1 = 0;
                for (var i = 0; i < data.length; i++) {
                    seria1++;
                    t1.row.add([
                        seria1,
                        data[i].ServiceName,
                        data[i].ServiceQnt,
                        data[i].ServiceNote
                    ]).draw();
                }
            }
        })
    }

    function Print(button) {
        Swal.fire({
            title: "@T("Confirm","Confirm")",
            imageUrl: "/Images/Quationimg.jpg",
            imageWidth: 550,
            imageHeight: 225,
            text: "@T("Msg_ConfirmPrintOne","Are you Sure you want to Print Claim Form Pdf?")",
            showCancelButton: true,
            confirmButtonText: "@T("Confirm","Confirm")",
            cancelButtonColor: "#700c0c"
        }).then((result) => {
            if (result.isConfirmed) {
                var row = $(button).closest("TR");
                var Approval_ID = row[0].cells.item(1).innerHTML;
                window.open('@Url.Action("GenerateReport_PrintClaimForm", "ClaimForm")?typeOfReport=PDF' + '&ApprovalID=' + Approval_ID, '_self');
            }
        });
    }

    function Delete(button) {
        Swal.fire({
            title: "@T("Confirm","Confirm")",
            imageUrl: "/Images/Quationimg.jpg",
            imageWidth: 550,
            imageHeight: 225,
            text: "@T("Msg_ConfirmDelete","Are you Sure you want to Delete Invoice?")",
            showCancelButton: true,
            confirmButtonText: "@T("Confirm","Confirm")",
            cancelButtonColor: "#700c0c"
        }).then((result) => {
            if (result.isConfirmed) {
                exShowLoading();

                var row = $(button).closest("TR");
                var ClaimID = row[0].cells.item(1).innerHTML;

                $.get("/ClaimForm/Delete_Invoice", { CLaimID: ClaimID }, function (data) {
                    exHideLoading();

                    if (data == "Done") {
                        Swal.fire("@T("Success","Success")", "@T("Msg_DeletedOk","Invoice is Deleted Successfuly")", "success");
                        $('#Search').click();
                    }
                    else if (data == "Error") {
                        Swal.fire("@T("Warning","Warning !")", "@T("Msg_DeleteError","Make Error In This Claim")", "warning");
                    }
                    else {
                        var batchNumber = data[0];
                        var RecDate = moment(data[1]).format("DD-MM-YYYY");

                        var errortext = "@T("Msg_CannotDeleteSent","Claim Can not Deleted Because Claim are Sent To Medi Gold Accounting To Pay")"
                            + "<br> @T("BatchNumber","Batch Number") : " + batchNumber
                            + "<br> @T("BatchDate","Batch Date") : " + RecDate;

                        Swal.fire("@T("Warning","Warning !")", errortext, "warning");
                    }
                })
            }
        });
    }
</script>


@{
    ViewBag.Title = "ClaimServices";
    // ✅ نفس النظام
    Layout = "~/Views/Shared/_LayoutV2.cshtml";

    // ✅ Localization helper (Resource file: ClaimServices.resx / ClaimServices.ar.resx)
    Func<string, string, string> T = (key, fallback) =>
    {
        try
        {
            var o = HttpContext.GetGlobalResourceObject("ClaimServices", key);
            return (o == null) ? fallback : o.ToString();
        }
        catch { return fallback; }
    };
}


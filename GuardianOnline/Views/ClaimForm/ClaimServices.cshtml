<script type="text/javascript">
    $(document).ready(function () {

        $("#Loadingg").hide();
        $("#backring1").hide();

        $("#fDiagnosis").on("keyup", function () {
            var value = $(this).val().toLowerCase();
            var incompleteTasks = document.getElementById('FirstDiagnosis_List');
            incompleteTasks.innerHTML = '';
            $.get("/ClaimForm/select_diagnosis", { id: value }, function (data) {
                for (var i = 0; i < data.length; i++) {
                    var li = document.createElement('option');
                    li.value = data[i];
                    incompleteTasks.appendChild(li);
                }
            })
        });

        $("#sDiagnosis").on("keyup", function () {
            var value = $(this).val().toLowerCase();
            var incompleteTasks = document.getElementById('SecondDiagnosis_List');
            incompleteTasks.innerHTML = '';
            $.get("/ClaimForm/select_diagnosis", { id: value }, function (data) {
                for (var i = 0; i < data.length; i++) {
                    var li = document.createElement('option');
                    li.value = data[i];
                    incompleteTasks.appendChild(li);
                }
            })
        });

        $("#tDiagnosis").on("keyup", function () {
            var value = $(this).val().toLowerCase();
            var incompleteTasks = document.getElementById('ThirdDiagnosis_List');
            incompleteTasks.innerHTML = '';
            $.get("/ClaimForm/select_diagnosis", { id: value }, function (data) {
                for (var i = 0; i < data.length; i++) {
                    var li = document.createElement('option');
                    li.value = data[i];
                    incompleteTasks.appendChild(li);
                }
            })
        });

        $("#New_Claim_Service").hide();
        $("#edit_Claim_Service").hide();
        $("body").on("click", "#Add_New_Claim_Service", function () {
            $("#Add_Claim_Serviceee").show();
            $("#New_Claim_Service").show();
            $("#edit_Claim_Service").hide();
        });

        $('#Claim_Services').DataTable({ paging: false });
        $('#Claim_Services2').DataTable({ paging: true });
        $('#Claim_Services2_Stoped').DataTable({});
        $('#Claim_Services2_Done').DataTable({});
        $('#ClaimFormTable').DataTable({ paging: true });

        serial = 0;

        $("body").on("click", "#New_Claim_ServiceE", function () {

            $("#backring1").show();
            $("#Loadingg").show();

            $.get("/ClaimForm/Check_ServiceName", { id: $('#selectServicelist').val() }, function (data) {

                $("#Loadingg").hide();
                $("#backring1").hide();

                if (data != "") {
                    if (($('#selectServicelist').val() == "")) {
                        Swal.fire("@T("Warning","Warning !")", "@T("Msg_ServiceRequired","Select Service Name is Required")", "warning");
                    }
                    else {
                        var isexist = 0;
                        $("#Claim_Services TBODY TR").each(function () {
                            var row = $(this);
                            var dt = $('#Claim_Services').DataTable();
                            if (dt != null) {
                                if (dt.rows().count() > 0) {
                                    var newService_Name = $('#selectServicelist').val();
                                    var Service_Name = row.find("TD").eq(1).text();
                                    if (newService_Name == Service_Name) { isexist = 1; }
                                }
                            }
                        });

                        if (isexist == 0) {
                            var t = $('#Claim_Services').DataTable();
                            var btnEdit = "<button type='button' class='btn btn-success' data-bs-toggle='modal' data-bs-target='#myModal' onclick='edited(this);'>@T("Edit","Edit")</button>";
                            var btnRemove = "<button type='button' class='btn btn-danger' onclick='Removed(this);'>@T("Remove","Remove")</button>";
                            serial++;
                            t.row.add([serial, $('#selectServicelist').val()
                                , $('#SystemPrice').val(), $('#quntity').val(), $('#Requested_Price').val(), btnEdit, btnRemove
                            ]).draw();
                            Swal.fire("@T("Success","Success")", "@T("Msg_ServiceInserted","Claim Service is inserted to Services Successfully")", "success");
                        }
                        else {
                            Swal.fire("@T("Warning","Warning !")", "@T("Msg_ServiceExists","Claim Service is Added Since while in Provider Services.")", "warning");
                        }
                    }
                }
                else {
                    Swal.fire("@T("Warning","Warning !")", "@T("Msg_SelectCorrectService","Select Correct Service Name")", "warning");
                }
            });
        });

        $("body").on("click", "#edit_Claim_ServiceE", function () {
            $("#backring1").show();
            $("#Loadingg").show();

            $.get("/ClaimForm/Check_ServiceName", { id: $('#selectServicelist').val() }, function (data) {
                $("#Loadingg").hide();
                $("#backring1").hide();

                if (data != "") {
                    if (($('#selectServicelist').val() == "")) {
                        Swal.fire("@T("Warning","Warning !")", "@T("Msg_ServiceRequired","Select Service Name is Required")", "warning");
                    }
                    else {
                        var Row_id = $('#edited_row_id').val() - 1;
                        var t = $('#Claim_Services').DataTable();
                        if ($('#selectServicelist').val() != "") { t.cell(Row_id, 1).data($('#selectServicelist').val()).draw(); }
                        if ($('#SystemPrice').val() != "") { t.cell(Row_id, 2).data($('#SystemPrice').val()).draw(); }
                        if ($('#quntity').val() != "") { t.cell(Row_id, 3).data($('#quntity').val()).draw(); }
                        if ($('#Requested_Price').val() != "") { t.cell(Row_id, 4).data($('#Requested_Price').val()).draw(); }

                        Swal.fire("@T("Success","Success")", "@T("Msg_ServiceUpdated","Claim Service is updated.")", "success");
                    }
                }
                else {
                    Swal.fire("@T("Warning","Warning !")", "@T("Msg_SelectCorrectService","Select Correct Service Name")", "warning");
                }
            });
        });
    });

    function Removed(button) {
        var row = $(button).closest("TR");
        var name = $("TD", row).eq(0).html();

        Swal.fire({
            title: "@T("Confirm","Confirm")",
            imageUrl: "/Images/Quationimg.jpg",
            imageWidth: 550,
            imageHeight: 225,
            text: "@T("Q_DeleteRow","Do you want to delete:")" + " " + name,
            showCancelButton: true,
            confirmButtonText: "@T("Confirm","Confirm")",
            cancelButtonColor: "#700c0c"
        }).then((result) => {
            if (result.isConfirmed) {
                var table = $('#Claim_Services').DataTable();
                table.rows(row[0].rowIndex - 1).remove().draw();
            }
        });
    };

    function edited(button) {
        $("#Add_Claim_Serviceee").show();

        $.get("/ClaimForm/Get_ClaimFormImage", { id: Claimform_number, CmcTriger: Cmc_Triger }, function (data) {

            $("#Loadingg").hide();
            $("#backring1").hide();

            if (data != "") {
                let image = document.getElementById("image");

            title: "@T("Confirm","Confirm")",
            imageUrl: "/Images/Quationimg.jpg",
            imageWidth: 550,
            imageHeight: 225,
            text: "@T("Q_DeleteClaimForm","Are you sure you want to Delete ClaimForm Number?")",

@Html.Hidden("Get", Url.Action("Get", "Customer"))
@Html.Hidden("Getmessages", Url.Action("Getmessages", "Customer"))
@Html.Hidden("Get1", Url.Action("Get1", "Customer"))

<style>
    /* =========================================
       ClaimServices V2 - Clean UI (Front Only)
       ========================================= */
    .cs-card {
        margin-bottom: 18px !important;
        padding: 0 !important;
        overflow: hidden;
    }

        .cs-card legend {
            display: block;
            width: 100%;
            margin: 0 !important;
            padding: 12px 14px !important;
            background: rgba(24,169,153,.10);
            border-bottom: 1px solid rgba(0,0,0,.08);
            border-top-left-radius: 18px;
            border-top-right-radius: 18px;
            background: rgba(13,110,253,.10);
        }
        /* Member Validation */
        .cs-card.cs-sec-validation legend {
            background: rgba(13,110,253,.12);
        }

        /* ClaimForm Image */
        .cs-card.cs-sec-claimimage legend {
            background: rgba(24,169,153,.12);
        }

        /* Approval Waiting */
        .cs-card.cs-sec-waiting legend {
            background: rgba(13,110,253,.12);
        }

        /* Stopped */
        .cs-card.cs-sec-stopped legend {
            background: rgba(220,53,69,.12);
        }

        /* Done */
        .cs-card.cs-sec-done legend {
            background: rgba(25,135,84,.12);
        }

        /* Provider Services */
        .cs-card.cs-sec-provider legend {
            background: rgba(111,66,193,.12); /* purple light */
        }
    .cs-card-body {
        padding: 14px !important;
    }

    .cs-card .dataTables_wrapper {
        margin-top: 8px;
    }

    .cs-card .dataTables_filter,
    .cs-card .dataTables_length {
        margin-bottom: 10px;
    }
    .cs-page .cs-shell { max-width: 1280px; margin: 0 auto; padding: 12px 14px 28px; }

    .cs-header{
        display:flex; justify-content:space-between; align-items:flex-start;
        gap:12px; flex-wrap:wrap; margin: 10px 0 16px;
    }
    .cs-title{ font-size:22px; font-weight:900; color:#0b2b40; margin:0; }
    .cs-sub{ font-size:13px; font-weight:700; color: rgba(15,23,42,.65); margin-top:4px; }

    .cs-actions{ display:flex; gap:10px; flex-wrap:wrap; }
    .cs-btn{ border-radius:14px; font-weight:900; padding:10px 14px; display:inline-flex; gap:10px; align-items:center; white-space:nowrap; }

    /* Cards */
    .cs-card{
        background:#fff;
        border:1px solid rgba(0,0,0,.08);
        border-radius:18px;
        box-shadow: 0 12px 30px rgba(15,23,42,.06);
        padding: 14px;
        margin-bottom: 14px;
    }
    fieldset.scheduler-border{ border:0 !important; padding:0 !important; margin:0 !important; box-shadow:none !important; }
    .cs-card legend{
        float:none; width:auto; padding:0 10px;
        font-size:14px; font-weight:900; color:#0b2b40;
        margin-bottom: 8px;
    }
    .cs-card-title{ font-size:16px; font-weight:900; color:#0b2b40; margin:0 0 10px; }

    /* Inputs unify (keep IDs) */
    #Card_number, #ClaimForm_Number, #ProcedureDatee,
    #selectServicelist, #fDiagnosis, #sDiagnosis, #tDiagnosis,
    #SystemPrice, #Requested_Price, #quntity{
        border-radius: 14px;
        min-height: 46px;
        font-size: 15px;
        font-weight: 800;
        padding: 10px 12px;
    }
    #Card_number, #ClaimForm_Number, #ProcedureDatee, #selectServicelist,
    #fDiagnosis, #sDiagnosis, #tDiagnosis{
        width: 100% !important;
        max-width: 100% !important;
        min-width: 0 !important;
    }

    /* Image box */
    #boxx{
        display:flex; align-items:center; justify-content:center;
        margin: 10px auto;
        width:100%; max-width: 340px;
        background:#fff;
        border-radius:22px;
        border:1px solid rgba(0,0,0,.08);
        box-shadow: 0 10px 26px rgba(15,23,42,.06);
        padding:16px;
        transition: .2s ease;
    }
    #boxx:hover{ transform: translateY(-2px); box-shadow: 0 18px 36px rgba(15,23,42,.10); }
    .cs-img{ max-width:100%; height:auto; max-height: 150px; object-fit:contain; display:block; margin:0 auto; }
    .cs-caption h1{ font-size:18px !important; margin:8px 0 2px !important; color:#0b2b40 !important; font-weight:900 !important; }
    .cs-caption h5{ font-size:13px !important; margin:0 !important; color: rgba(15,23,42,.70) !important; font-weight:800 !important; }

    /* Tables responsive + modern header */
    .cs-table-wrap{
        overflow:auto;
        border-radius:14px;
        border:1px solid rgba(0,0,0,.08);
        background:#fff;
    }

    /* Override old table789/table7899 strongly */
    table.table789, table.table7899{
        width:100% !important;
        border-collapse: collapse !important;
        margin:0 !important;
        text-align:center !important;
        background:#fff !important;
        border:0 !important;
    }
    table.table789 th, table.table7899 th{
        background: rgba(24,169,153,.12) !important;
        color:#0b2b40 !important;
        font-weight:900 !important;
        font-size:13px !important;
        padding:10px !important;
        border:1px solid rgba(0,0,0,.08) !important;
        white-space:nowrap !important;
    }
    table.table789 td, table.table7899 td{
        font-size:13px !important;
        font-weight:700 !important;
        padding:10px !important;
        border:1px solid rgba(0,0,0,.08) !important;
        white-space:nowrap !important;
        background:#fff !important;
    }

    /* Section color indicator */
    #Expended_services{ border-left:6px solid #0d6efd; }
    #Expended_services_Stoped{ border-left:6px solid #dc3545; }
    #Expended_services_Done{ border-left:6px solid #198754; }

    /* Buttons */
    .cs-center-actions{ display:flex; justify-content:center; gap:12px; flex-wrap:wrap; margin: 10px 0; }
    .cs-center-actions .btn, .cs-center-actions .btn-lg{
        border-radius:14px;
        font-weight:900;
        padding:10px 18px;
    }

    /* Links */
    #link, #link1{
        text-decoration:none;
        display:inline-block;
        padding:10px 14px;
        border-radius:14px;
        font-weight:900;
    }
    #link:hover, #link1:hover{ background: rgba(0,0,0,.06); color:#000; }
    .round{ background-color: teal; color: white; }

    /* Loading overlay */
    #backring1{ background-color: rgba(0,0,0,.25); display:none; position:fixed; inset:0; z-index: 9998; }
    .ring1{
        position: fixed; top:50%; left:50%; transform: translate(-50%,-50%);
        width:150px; height:150px; border:3px solid #9ac3b8; border-radius:50%;
        text-align:center; line-height:150px; font-size:20px; letter-spacing:2px;
        color:#fff000; text-transform:uppercase; text-shadow:0 0 10px #fff000;
        background-color:#11395c; box-shadow:0 0 20px rgba(0,0,0,.35);
        display:none; z-index: 9999;
    }
    .ring1:before{
        content:''; position:absolute; top:0; left:0; width:100%; height:100%;
        border:3px solid transparent; border-top:3px solid #fff000; border-right:3px solid #fff000;
        box-shadow:0 0 1em white, 0 0 0 1000vw rgba(224,222,222,.70);
        border-radius:50%;
        animation: animateC1 2s linear infinite;
    }
    spana1{ display:block; position:absolute; top:calc(50% - 2px); left:50%; width:50%; height:4px; background:transparent; transform-origin:left; animation: animate1 2s linear infinite; }
    spana1:before{ content:''; position:absolute; width:16px; height:16px; border-radius:50%; background:#fff000; top:-6px; right:-8px; box-shadow:0 0 20px #fff000; }
    @@keyframes animateC1{ 0%{transform:rotate(0deg)} 100%{transform:rotate(360deg)} }
    @@keyframes animate1{ 0%{transform:rotate(45deg)} 100%{transform:rotate(405deg)} }
</style>
<div class="cs-page">
    <div class="cs-shell">

        <div class="cs-header">
            <div>
                <h2 class="cs-title">@T("Title", "Claim Services")</h2>
                <div class="cs-sub">@T("SubTitle", "Validate member, view claim form images, add services, and request approval")</div>
            </div>

            <div class="cs-actions">
                <a class="btn btn-outline-secondary cs-btn" href="@Url.Action("DoctorHome","ClaimForm")" id="link">
                    @T("BackHome", "« Back to Main Home")
                </a>

                <a class="btn btn-outline-primary cs-btn" href="@Url.Action("ProviderClaimFormApproved","ClaimForm")">
                    @T("GoApproved", "Go to ClaimForm Approved »")
                </a>
            </div>
        </div>

        @* =========================
            Member Validation
            ========================= *@
        <fieldset class="scheduler-border cs-card cs-sec-validation">
            <legend class="scheduler-border">@T("MemberValidation", "Member Validation")</legend>

            <div class="cs-card-body">
                <div class="cs-card-title">@T("MemberValidationTitle", "Validate Member Card")</div>

                <div class="row g-3 align-items-end">
                    <div class="col-12 col-lg-9">
                        @Html.Label("Card Number", htmlAttributes: new { @class = "form-label fw-bold", @id = "Card_numberLabel" })
                        @Html.Editor("c1", new { htmlAttributes = new { @class = "form-control", @id = "Card_number", @Name = "Card_number", required = "required", placeholder = T("CardPlaceholder", "Enter Card Number") } })
                        @Html.ValidationMessage("c1", "", new { @class = "text-danger" })
                    </div>

                    <div class="col-12 col-lg-3 d-grid">
                        <button type="button" id="Check_CardNumber" class="btn btn-primary btn-lg" style="border-radius:14px;font-weight:900">
                            @T("CheckValidation", "Check Validation")
                        </button>
                    </div>
                </div>

                <div class="mt-3 cs-table-wrap">
                    <table class="table789" id="Member_Info_Table" cellpadding="0" cellspacing="0">
                        <thead>
                            <tr>
                                <th>@T("MemberName", "Member Name")</th>
                                <th>@T("CustomerName", "Customer Name")</th>
                                <th>@T("CardNumber", "Card Number")</th>
                                <th>@T("ContractNumber", "Contract Number")</th>
                                <th>@T("Plan", "Plan")</th>
                                <th>@T("ActiveDate", "Active Date")</th>
                                <th>@T("ActivityStatus", "Activity Status")</th>
                                <th>@T("DeactiveDate", "Deactive Date")</th>
                                <th>@T("BirthDate", "Member Birth Date")</th>
                                <th>@T("Age", "Member Age")</th>
                                <th>@T("SexType", "Sex Type")</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </fieldset>

        @* =========================
            ClaimForm Image + List
            ========================= *@
        <fieldset class="scheduler-border cs-card cs-sec-claimimage" id="ClaimForm_image">
            <legend class="scheduler-border">@T("ClaimFormImageContent", "Member ClaimForm Image Content")</legend>

            <div class="cs-card-body">
                <div class="cs-card-title">@T("ClaimFormsList", "ClaimForms List")</div>

                <div class="cs-table-wrap">
                    <table class="table7899" id="ClaimFormTable" cellpadding="0" cellspacing="0">
                        <thead>
                            <tr>
                                <th>@T("Serial", "Serial")</th>
                                <th>@T("ClaimFormNumber", "ClaimForm Number")</th>
                                <th></th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>

                <div class="mt-3 text-center" id="imgpost">
                    <div class="row justify-content-center">
                        <div class="col-12 col-md-6 col-lg-4">
                            <div id="boxx">
                                <a id="image" href="" target="_blank" style="text-decoration:none">
                                    <div>
                                        <img src="~/Images/ClaimFormImg.jpg" class="cs-img" />
                                        <div class="cs-caption text-center mt-2">
                                            <h1>@T("ClickHere", "Click Here")</h1>
                                            <h5>@T("ShowClaimFormImage", "Show ClaimForm Image")</h5>
                                        </div>
                                    </div>
                                </a>
                            </div>

                            <div class="d-flex justify-content-end gap-2 mt-2">
                                <div id="button_open_div">
                                    <button type="button" id="button_open" class="btn btn-success" style="border-radius:14px;font-weight:900">
                                        @T("OpenImage", "Open Image")
                                    </button>
                                </div>

                                <div id="button_Close_div">
                                    <button type="button" id="button_Close" class="btn btn-danger" style="border-radius:14px;font-weight:900">
                                        @T("CloseImage", "Close Image")
                                    </button>
                                </div>
                            </div>

                            <div class="text-center mt-3">
                                <a id="link1" class="round" href="javascript:void(0);">
                                    @T("UploadNewClaimFormImage", "Upload New ClaimForm Image")
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </fieldset>

        @* =========================
            Approval Services Waiting
            ========================= *@
        <fieldset class="scheduler-border cs-card cs-sec-waiting" id="Expended_services">
            <legend class="scheduler-border">@T("ApprovalWaiting", "Approval Services Waiting")</legend>

            <div class="cs-card-body">
                <div class="cs-table-wrap">
                    <table class="table7899" id="Claim_Services2" cellpadding="0" cellspacing="0">
                        <thead>
                            <tr>
                                <th>@T("Serial", "Serial")</th>
                                <th>@T("ServiceName", "Service Name")</th>
                                <th>@T("ServiceQnt", "Service Qnt")</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </fieldset>

        @* =========================
            Approval Services Stopped
            ========================= *@
        <fieldset class="scheduler-border cs-card cs-sec-stopped" id="Expended_services_Stoped">
            <legend class="scheduler-border">@T("ApprovalStopped", "Approval Services Stopped")</legend>

            <div class="cs-card-body">
                <div class="cs-table-wrap">
                    <table class="table7899" id="Claim_Services2_Stoped" cellpadding="0" cellspacing="0">
                        <thead>
                            <tr>
                                <th>@T("Serial", "Serial")</th>
                                <th>@T("ServiceName", "Service Name")</th>
                                <th>@T("ServiceQnt", "Service Qnt")</th>
                                <th>@T("RefuseNote", "Refuse Note")</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </fieldset>

        @* =========================
            Approval Services Done
            ========================= *@
        <fieldset class="scheduler-border cs-card cs-sec-done" id="Expended_services_Done">
            <legend class="scheduler-border">@T("ApprovalDone", "Approval Service Done")</legend>

            <div class="cs-card-body">
                <div class="cs-table-wrap">
                    <table class="table7899" id="Claim_Services2_Done" cellpadding="0" cellspacing="0">
                        <thead>
                            <tr>
                                <th>@T("Serial", "Serial")</th>
                                <th>@T("ServiceName", "Service Name")</th>
                                <th>@T("ServiceQnt", "Service Qnt")</th>
                                <th>@T("Note", "Note")</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </fieldset>

        @* =========================
            Provider Services
            ========================= *@
        <fieldset class="scheduler-border cs-card cs-sec-provider" id="Provider_services">
            <legend class="scheduler-border">@T("ProviderServices", "Provider Services")</legend>

            <div class="cs-card-body">
                <div class="cs-card-title">@T("AddServicesTitle", "Add Services & Diagnoses")</div>

                <div class="row g-3 align-items-end">
                    <div class="col-12 col-lg-6">
                        <label id="ClaimForm_NumberLabel" class="form-label fw-bold">@T("ClaimFormNumber", "ClaimForm Number")</label>
                        <input type="text" id="ClaimForm_Number" name="ClaimForm_Number" class="form-control deletable" required placeholder="@T("ClaimFormPlaceholder","Enter ClaimForm Number")">
                    </div>

                    <div class="col-12 col-lg-6">
                        @{
                            string s = DateTime.Now.ToString("yyyy-MM-dd");
                        }
                        <label id="ProcedureDateLabel" class="form-label fw-bold">@T("ProcedureDate", "Procedure Date")</label>
                        <input type="date" value="@s" id="ProcedureDatee" name="ProcedureDatee" class="form-control" />
                    </div>
                </div>

                <div class="row g-3 mt-1">
                    <div class="col-12" id="FirstDiagnos">
                        <label class="form-label fw-bold">@T("FirstDiagnosis", "First Diagnosis")</label>
                        <div class="d-flex flex-wrap gap-2">
                            <div class="flex-grow-1">
                                <input list="FirstDiagnosis_List" type="text" id="fDiagnosis" name="fDiagnosis" class="form-control deletable" placeholder="@T("DiagnosisPlaceholder","Type diagnosis")">
                                <datalist id="FirstDiagnosis_List"></datalist>
                            </div>
                            <input type="button" value="@T("AddSecondDiagnosis","Add Second Diagnosis")" id="Add_Second_Diagnosis" class="btn btn-success" style="border-radius:14px;font-weight:900" />
                        </div>
                    </div>

                    <div class="col-12" id="SecondDiagnos">
                        <label class="form-label fw-bold">@T("SecondDiagnosis", "Second Diagnosis")</label>
                        <div class="d-flex flex-wrap gap-2">
                            <div class="flex-grow-1">
                                <input list="SecondDiagnosis_List" type="text" id="sDiagnosis" name="sDiagnosis" class="form-control deletable" placeholder="@T("DiagnosisPlaceholder","Type diagnosis")">
                                <datalist id="SecondDiagnosis_List"></datalist>
                            </div>
                            <input type="button" value="@T("AddThirdDiagnosis","Add Third Diagnosis")" id="Add_Third_Diagnosis" class="btn btn-success" style="border-radius:14px;font-weight:900" />
                            <input type="button" value="@T("DeleteSecondDiagnosis","Delete Second Diagnosis")" id="Delete_Second_Diagnosis" class="btn btn-danger" style="border-radius:14px;font-weight:900" />
                        </div>
                    </div>

                    <div class="col-12" id="ThirdDiagnos">
                        <label class="form-label fw-bold">@T("ThirdDiagnosis", "Third Diagnosis")</label>
                        <div class="d-flex flex-wrap gap-2">
                            <div class="flex-grow-1">
                                <input list="ThirdDiagnosis_List" type="text" id="tDiagnosis" name="tDiagnosis" class="form-control deletable" placeholder="@T("DiagnosisPlaceholder","Type diagnosis")">
                                <datalist id="ThirdDiagnosis_List"></datalist>
                            </div>
                            <input type="button" value="@T("DeleteThirdDiagnosis","Delete Third Diagnosis")" id="Delete_Third_Diagnosis" class="btn btn-danger" style="border-radius:14px;font-weight:900" />
                        </div>
                    </div>
                </div>

                <div class="cs-center-actions mt-3">
                    <input type="submit"
                           value="@T("AddNewService","Add New Service")"
                           data-bs-toggle="modal"
                           data-bs-target="#myModal"
                           id="Add_New_Claim_Service"
                           class="btn btn-primary btn-lg" />
                </div>

                <div class="cs-table-wrap">
                    <table class="table7899" id="Claim_Services" cellpadding="0" cellspacing="0">
                        <thead>
                            <tr>
                                <th>@T("Serial", "Serial")</th>
                                <th>@T("ServiceName", "Service Name")</th>
                                <th>@T("ServicePrice", "Service Price")</th>
                                <th>@T("ServiceQnt", "Service Qnt")</th>
                                <th>@T("RequestedPrice", "Requested Price")</th>
                                <th></th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>

                @* Modal (front-only styling) *@
                <div class="modal" id="myModal">
                    <div class="modal-dialog modal-lg modal-dialog-centered">
                        <div class="modal-content" style="border-radius:18px;overflow:hidden">
                            <div class="modal-header">
                                <h2 class="modal-title" style="font-weight:900;color:#0b2b40">@T("ModalTitle", "Claim Services")</h2>
                                <button type="button" class="btn-close btn-danger" data-bs-dismiss="modal"></button>
                            </div>

                            <div class="modal-body">
                                <div id="Add_Claim_Serviceee">
                                    <div class="row g-3">
                                        <div class="col-12 col-lg-6">
                                            @Html.Label("Service list", htmlAttributes: new { @class = "form-label fw-bold" })
                                            <div id="selectServicelistdiv">
                                                <input list="Service_List" type="text" id="selectServicelist" name="ServicelIST" class="form-control deletable" placeholder="@T("ServicePlaceholder","Type service name")">
                                                <datalist id="Service_List"></datalist>
                                            </div>
                                        </div>

                                        <div class="col-12 col-lg-6">
                                            @Html.Label("Price", htmlAttributes: new { @class = "form-label fw-bold" })
                                            @Html.Editor("Citydropdown1", new
                                            {
                                                htmlAttributes = new
                                                {
                                                    @class = "form-control",
                                                    @id = "SystemPrice",
                                                    @Name = "SystemPrice",
                                                    @Value = "1.00",
                                                    @readonly = "readonly"
                                                }
                                            })
                                        </div>

                                        <div class="col-12 col-lg-6">
                                            @Html.Label("Requested Price", htmlAttributes: new { @class = "form-label fw-bold" })
                                            @Html.Editor("Citydropdown1", new
                                            {
                                                htmlAttributes = new
                                                {
                                                    @class = "form-control",
                                                    @id = "Requested_Price",
                                                    @Name = "Requested_Price",
                                                    @Value = "1.00"
                                                }
                                            })
                                        </div>

                                        <div class="col-12 col-lg-6">
                                            @Html.Label("Quntity", htmlAttributes: new { @class = "form-label fw-bold" })
                                            @Html.Editor("Citydropdown1", new
                                            {
                                                htmlAttributes = new
                                                {
                                                    @class = "form-control",
                                                    @id = "quntity",
                                                    @Name = "quntity",
                                                    @Value = "1.00"
                                                }
                                            })
                                        </div>
                                    </div>

                                    <div class="cs-center-actions mt-4" id="New_Claim_Service">

                $("#backring1").show();
                $("#Loadingg").show();

                var row = $(button).closest("TR");
                var Claimform_number = row[0].cells.item(1).innerHTML;

                $.get("/ClaimForm/delete_ClaimFormImage", { id: Claimform_number }, function (data) {
                    $("#Loadingg").hide();
                    $("#backring1").hide();

                    if (data == "falsee") {
                        Swal.fire("@T("Error","Error !")", "@T("Msg_DeleteNotAllowed1","ClaimForm Number can not be deleted because Provider made approval. If you want delete, call CMC.")", "error");
                    }
                    else if (data == "falsee1") {
                        Swal.fire("@T("Error","Error !")", "@T("Msg_DeleteNotAllowed2","ClaimForm Number can not be deleted because different provider. If you want delete, call CMC.")", "error");
                    }
                    else {
                        Swal.fire("@T("Success","Success")", "@T("Msg_Deleted","ClaimForm Number is Deleted Successfully")", "success");
                        $('#Check_CardNumber').click();
                    }
                })
            }
        });
    };
</script>

<script type="text/javascript">
    $(document).ready(function () {
        $("#selectServicelist").on("keyup", function () {
            var value = $(this).val().toLowerCase();
            var incompleteTasks = document.getElementById('Service_List');
            incompleteTasks.innerHTML = '';
            $.get("/ClaimForm/select_Servicess", { id: value }, function (data) {
                for (var i = 0; i < data.length; i++) {
                    var li = document.createElement('option');
                    li.value = data[i];
                    incompleteTasks.appendChild(li);
                }
            })
        });

        $("#selectServicelist").change(function () {
            var ServiceNam = $('#selectServicelist').val();
            if (ServiceNam != "") {
                $.get("/ClaimForm/Get_service_data", { selectServicelist: ServiceNam }, function (data) {
                    if (data[0] == 1) {
                        $('#SystemPrice').val(data[1].toLocaleString('en-US', { minimumFractionDigits: 2 }));
                        $('#Requested_Price').val(data[1].toLocaleString('en-US', { minimumFractionDigits: 2 }));
                    }
                    else {
                        var pri = 0;
                        $('#SystemPrice').val(pri.toLocaleString('en-US', { minimumFractionDigits: 2 }));
                        $('#Requested_Price').val(pri.toLocaleString('en-US', { minimumFractionDigits: 2 }));
                        Swal.fire("@T("Warning","Warning !")", data[1], "warning");
                    }
                })
            }
        });

        $("body").on("click", "#Doctor_Add_claim", function () {

            Swal.fire({
                title: "@T("Confirm","Confirm")",
                imageUrl: "/Images/Quationimg.jpg",
                imageWidth: 550,
                imageHeight: 225,
                text: "@T("Q_SendToCMC","You currently sent Claim Form to approve from CMC. Are you sure you want to send?")",
                showCancelButton: true,
                confirmButtonText: "@T("Confirm","Confirm")",
                cancelButtonColor: "#700c0c"
            }).then((result) => {

                if (result.isConfirmed) {
                    $("#backring1").show();
                    $("#Loadingg").show();

                    var Claims_Services = new Array();
                    $("#Claim_Services TBODY TR").each(function () {
                        var row = $(this);
                        var Claim_Service = {};
                        var dt = $('#Claim_Services').DataTable();
                        if (dt != null) {
                            if (dt.rows().count() > 0) {
                                Claim_Service.Service_Name = row.find("TD").eq(1).text();
                                Claim_Service.Service_Qnt = parseFloat((row.find("TD").eq(3).text()).replace(/,/g, ''));
                                Claim_Service.Requested_Price = parseFloat((row.find("TD").eq(4).text()).replace(/,/g, ''));

                                Claim_Service.Claim_Form_Number = $('#ClaimForm_Number').val();
                                Claim_Service.ProcedureDat = $('#ProcedureDatee').val();
                                Claim_Service.Card_numberr = $('#Card_number').val();

                                Claim_Service.FirstDiagnosis = $('#fDiagnosis').val();
                                Claim_Service.SecondDiagnosis = $('#sDiagnosis').val();
                                Claim_Service.ThirdDiagnosis = $('#tDiagnosis').val();

                                Claims_Services.push(Claim_Service);
                            }
                        }
                    });

                    $.ajax({
                        type: "POST",
                        url: "/ClaimForm/InsertClaims_Servicess",
                        data: JSON.stringify(Claims_Services),
                        contentType: "application/json; charset=utf-8",
                        dataType: "json",
                        success: function (r) {
                            $("#Loadingg").hide();
                            $("#backring1").hide();

                            if (r[0] == 0) {

                                var t = $('#Claim_Services').DataTable();
                                t.rows().remove().draw();
                                serial = 0;

                                var t3 = $('#Claim_Services2').DataTable(); t3.rows().remove().draw();
                                var t1 = $('#Claim_Services2_Stoped').DataTable(); t1.rows().remove().draw();
                                var t2 = $('#Claim_Services2_Done').DataTable(); t2.rows().remove().draw();

                                $("#imgpost").hide();
                                $("#button_open_div").hide();
                                $("#button_Close_div").hide();

                                $("#ClaimForm_image").hide();
                                $("#Expended_services").hide();
                                $("#Expended_services_Stoped").hide();
                                $("#Expended_services_Done").hide();
                                $("#Provider_services").hide();
                                $('#Card_number').val("");
                                $("#Member_Info_Table").hide();

                                Swal.fire("@T("Success","Success")", "@T("Msg_SentToCMC","Claim Form is sent to approve from CMC successfully")", "success")
                                    .then(function () {
                                        window.open('@Url.Action("ClaimServices", "ClaimForm")', '_self');
                                    });
                            }
                            else if (r[0] == 1) {
                                Swal.fire("@T("Error","Error !")", r[1], "error");
                            }
                            else {
                                Swal.fire("@T("Error","Error !")", "@T("Msg_BatchFull","Batch is Added Full Claims")", "error");
                            }
                        }
                    });
                }
            });
        });

        $("#quntity").change(function () {
            var quntityy = parseFloat(($('#quntity').val()).replace(/,/g, ''));
            if ($('#quntity').val() == "" || isNaN($('#quntity').val())) {
                quntityy = 1;
                $('#quntity').val(quntityy.toLocaleString('en-US', { minimumFractionDigits: 2 }));
            } else {
                $('#quntity').val(quntityy.toLocaleString('en-US', { minimumFractionDigits: 2 }));
            }
        });

        $("#SystemPrice").change(function () {
            var quntityy = parseFloat(($('#SystemPrice').val()).replace(/,/g, ''));
            if ($('#SystemPrice').val() == "" || isNaN($('#SystemPrice').val())) {
                quntityy = 1;
                $('#SystemPrice').val(quntityy.toLocaleString('en-US', { minimumFractionDigits: 2 }));
            } else {
                $('#SystemPrice').val(quntityy.toLocaleString('en-US', { minimumFractionDigits: 2 }));
            }
        });

        $("#Requested_Price").change(function () {
            var quntityy = parseFloat(($('#Requested_Price').val()).replace(/,/g, ''));
            if ($('#Requested_Price').val() == "" || isNaN($('#Requested_Price').val())) {
                quntityy = 1;
                $('#Requested_Price').val(quntityy.toLocaleString('en-US', { minimumFractionDigits: 2 }));
            } else {
                $('#Requested_Price').val(quntityy.toLocaleString('en-US', { minimumFractionDigits: 2 }));
            }
        });
    });
</script>


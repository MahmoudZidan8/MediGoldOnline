@model GuardianOnline.Infrastructure.MemberClaimForm

@{
    ViewBag.Title = "UploadMemberClaim";
    Layout = "~/Views/Shared/_LayoutV2.cshtml";

    Func<string, string, string> T = (key, fallback) =>
    {
        try
        {
            var o = HttpContext.GetGlobalResourceObject("UploadMemberClaim", key);
            return (o == null) ? fallback : o.ToString();
        }
        catch { return fallback; }
    };
}

@Scripts.Render("~/bundles/jquery")
@Scripts.Render("~/bundles/bootstrap")
<script src="~/Scripts/jquery.signalR-2.4.3.min.js"></script>
<script src="~/signalr/hubs"></script>

<link rel="stylesheet" href="~/Content/select2.min.css">
<script src="~/Scripts/select2.min.js"></script>
<script src="~/Scripts/moment-with-locales.min.js"></script>

<input type="hidden" id="trigger" value="0" />
<input type="hidden" id="triggercount" value="0" />
<input type="hidden" id="trigger1" value="0" />
<input type="hidden" id="triggercount1" value="0" />

@Html.Hidden("Get", Url.Action("Get", "Customer"))
@Html.Hidden("Getmessages", Url.Action("Getmessages", "Customer"))
@Html.Hidden("Get1", Url.Action("Get1", "Customer"))

<div class="ex-page">
    <div class="pv-shell">

        <div class="pv-header">
            <div>
                <div class="pv-title">
                    @T("PageTitle", "Member ClaimForm")
                </div>
                <div class="pv-sub">
                    @T("SubTitle", "Upload member claim form image and submit to system")
                </div>
            </div>

            <div class="pv-actions">
                <a class="btn btn-outline-secondary pv-btn"
                   href="@Url.Action("DoctorHome","ClaimForm")">
                    <i class="bi bi-arrow-left"></i>
                    @T("BackHome", "Back to Main Home")
                </a>
            </div>
        </div>

        @using (Html.BeginForm("UploadMemberClaim",
                               "ClaimForm",
                               FormMethod.Post,
                               new { enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()

            <div class="pv-card">

                <div class="pv-card-title">
                    @T("CardTitle", "Member ClaimForm Content")
                </div>

                @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                <div class="row g-4">

                    <div class="col-lg-6">
                        <label class="fw-bold mb-2">
                            @T("ClaimFormNumber", "ClaimForm Number")
                        </label>
                        @Html.EditorFor(m => m.ClaimFormNumber,
                            new { htmlAttributes = new { @class = "form-control form-control-lg", required = "required" } })
                        @Html.ValidationMessageFor(m => m.ClaimFormNumber, "", new { @class = "text-danger" })
                    </div>

                    <div class="col-lg-6">
                        <label class="fw-bold mb-2">
                            @T("CardNumber", "Card Number")
                        </label>
                        @Html.EditorFor(m => m.CardNumber,
                            new { htmlAttributes = new { @class = "form-control form-control-lg", required = "required" } })
                        @Html.ValidationMessageFor(m => m.CardNumber, "", new { @class = "text-danger" })
                    </div>

                    @* Hidden fields (زي ما هم عندك بالظبط) *@
                    @Html.HiddenFor(m => m.EntryID)
                    @Html.HiddenFor(m => m.EntryDate)
                    @Html.HiddenFor(m => m.MemberClaimformStatus, new { @Value = 1 })
                    @Html.HiddenFor(m => m.ProviderCat)

                    <div class="col-12">
                        <label class="fw-bold mb-2">
                            @T("ClaimImage", "ClaimForm Image")
                        </label>
                        <input type="file"
                               name="imgfile"
                               class="form-control form-control-lg"
                               required />
                        @Html.ValidationMessageFor(m => m.ClaimFormImage, "", new { @class = "text-danger" })
                    </div>

                </div>

                <div class="text-center mt-4">
                    <button type="submit"
                            class="btn btn-primary btn-lg px-5">
                        <i class="bi bi-upload"></i>
                        @T("Create", "Create")
                    </button>
                </div>

            </div>
        }

    </div>
</div>

@if (ViewBag.card_numberqq != null && ViewBag.card_numberqq != "")
{
    <script>
        $('#CardNumber').val("@ViewBag.card_numberqq");
    </script>
}

@if (ViewBag.ErorMessage != null)
{
    <script>
        Swal.fire("Error !","@ViewBag.ErorMessage","error");
    </script>
}


